PORT=3000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fern

# Redis (BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Polling interval in minutes (only when ENABLE_BACKGROUND_JOBS=true)
POLL_INTERVAL_MINUTES=5
ENABLE_BACKGROUND_JOBS=false

# Slack
SLACK_BOT_TOKEN=xoxb-11300213153507-11300255288019-ZMA39XdGpFBRcGgMgHxo3MkU
SLACK_CHANNELS=C01234567,C07654321

# Gmail (OAuth2 service account or user credentials)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=me@gmail.com
GMAIL_POLL_BACKFILL_LIMIT=20

# Transcripts — local directory or S3-compatible path
TRANSCRIPT_DIR=./data/transcripts

# Google AI (Gemini) — get key at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash-lite
# Min ms between Gemini calls (5000 ≈ 12 RPM; gemini-2.5-flash-lite free tier allows 15 RPM)
GEMINI_MIN_DELAY_MS=5000
GEMINI_MAX_RETRIES=3
# Max AI analyses per source per poll cycle (ingest is store-only; AI runs here)
AI_REPROCESS_PER_POLL=2
# Run AI backlog on npm run dev startup (false = only on scheduled 5-min poll)
AI_REPROCESS_ON_STARTUP=false

# Privacy
REDACT_PII=true
EXCLUDE_DM_CHANNELS=true
